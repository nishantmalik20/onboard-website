# Supabase — OnBoard admin backend
# Copy to .env.local for local dev; set the same names in Vercel for production.

# Client-side (exposed to the browser bundle; protected by Row Level Security):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (NEVER exposed to the browser — bypasses RLS):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email (existing quote/contact forms)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=
