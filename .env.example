# Supabase — OnBoard admin backend
# Copy to .env.local for local dev; set the same names in Vercel for production.

# Client-side (exposed to the browser bundle; protected by Row Level Security):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-side only (NEVER exposed to the browser — bypasses RLS):
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Bearer token Vercel sends on cron invocations (keep-alive heartbeat)
CRON_SECRET=

# Storage soft cap (MB). When the quotes bucket exceeds this, the daily cron
# deletes the oldest files to make room. Optional — defaults to 800 (of 1024).
STORAGE_SOFT_LIMIT_MB=

# Email (existing quote/contact forms)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL=
